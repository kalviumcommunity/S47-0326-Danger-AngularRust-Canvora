# Copy to `.env` and adjust for your machine. Do not commit real secrets.
# Used by Docker Compose (`docker compose --env-file .env up`) and local backend (`dotenv`).

# --- PostgreSQL (compose `db` service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=whiteboard
POSTGRES_PORT=5432

# Connection string for the Rust API (host `db` when using Compose; `localhost` for local Postgres).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/whiteboard

# --- Backend HTTP ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
RUST_LOG=info

# Auth & CORS (set strong JWT_SECRET in any shared environment)
JWT_SECRET=change-me-use-long-random-string
CORS_ALLOWED_ORIGIN=http://localhost:4200

# --- Frontend (Docker build / runtime documentation) ---
# Browser-reachable API URL when the SPA is built inside Docker (Compose default below).
PUBLIC_API_BASE_URL=http://localhost:8080
FRONTEND_PORT=80
